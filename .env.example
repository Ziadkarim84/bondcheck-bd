# ─── Database (Railway MySQL) ───────────────────────────────────────────────
DATABASE_URL=mysql://root:password@localhost:3306/bondcheck

# ─── Redis (Upstash — free tier) ────────────────────────────────────────────
# Get from: https://console.upstash.com → Create Database → Redis
REDIS_URL=rediss://default:YOUR_TOKEN@YOUR_ENDPOINT.upstash.io:6380

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string

# ─── Cloudinary (free: 25GB storage, 25GB bandwidth) ────────────────────────
# Get from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Firebase FCM (free, unlimited push notifications) ──────────────────────
# Get from: https://console.firebase.google.com → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@project.iam.gserviceaccount.com

# ─── Resend (free: 100 emails/day) ──────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# ─── Admin ──────────────────────────────────────────────────────────────────
# Set any strong secret — used to protect /admin/* endpoints
ADMIN_SECRET=your-admin-secret-key

# ─── App ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Frontend URL (for CORS) ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
