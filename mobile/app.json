{
  "expo": {
    "name": "BondCheck BD",
    "slug": "bondcheck-bd",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0284c7"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bondcheckbd.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0284c7"
      },
      "package": "com.bondcheckbd.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow BondCheck to access your camera to scan prize bonds."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0284c7",
          "androidMode": "default"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-1144671244479208~4979757958",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ]
    ],
    "scheme": "bondcheck",
    "extra": {
      "apiUrl": "https://bondcheck-bd-production.up.railway.app/v1",
      "eas": {
        "projectId": "8b9b9c47-7dde-4232-bc96-a8bd29678cc3"
      },
      "router": {}
    },
    "owner": "ziadkarim84"
  }
}
